# ===============================
# PASSENGER + FLASK-SOCKETIO CONFIGURATION
# ===============================
# Routes all requests (including /socket.io) to Flask app
# This ensures Socket.IO requests reach Flask-SocketIO instead of returning 404

PassengerEnabled on
PassengerAppRoot /home/impromptuindian/backend
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py

# ✅ CRITICAL: Route all requests to Flask app (including /socket.io)
# Without this, Apache looks for physical /socket.io folder and returns 404
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,L]
