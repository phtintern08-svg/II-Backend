PassengerEnabled on
PassengerAppRoot /home/impromptuindian/backend
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py
PassengerAppEnv production

Options -MultiViews
RewriteEngine On

# Important for Socket.IO
PassengerBufferUpload off

# Limit Passenger workers
PassengerMaxPoolSize 1
PassengerMinInstances 1
PassengerMaxInstancesPerApp 1

# ✅ Proxy Socket.IO to Gunicorn server (port 5001)
# This routes /socket.io requests to the standalone Socket.IO server
RewriteCond %{REQUEST_URI} ^/socket.io
RewriteRule ^socket.io/(.*)$ http://127.0.0.1:5001/socket.io/$1 [P,L]

# If file exists serve normally
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Everything else to Flask
RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,PT,L]
