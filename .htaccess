# ===============================
# PASSENGER CONFIGURATION
# ===============================

PassengerEnabled on
PassengerAppRoot /home/impromptuindian/backend
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py

PassengerAppEnv production
PassengerBaseURI /

# IMPORTANT: Disable buffering for Socket.IO
PassengerBufferUpload off

Options -MultiViews
RewriteEngine On

# ✅ CRITICAL: Route socket.io to Passenger (must be first)
RewriteRule ^socket.io/(.*)$ /socket.io/$1 [L]

# ✅ IMPORTANT: Allow socket.io through Passenger
RewriteCond %{REQUEST_URI} ^/socket.io
RewriteRule ^(.*)$ / [QSA,L]

# If file exists, serve normally
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Otherwise send request to Passenger
RewriteRule ^(.*)$ / [QSA,L]
