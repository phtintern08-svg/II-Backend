RewriteEngine On

# 1. THE BRIDGE: Forward all Socket.IO traffic to Port 3000
# NC = case-insensitive, P = Proxy, L = Last Rule
# This prevents the 404 by bypassing Passenger and routing to the stable standalone server
RewriteRule ^socket\.io/(.*) http://localhost:3000/socket.io/$1 [P,L]

# -------------------------------------------------------------------
# 2. Standard Passenger / Flask Config
# -------------------------------------------------------------------
PassengerEnabled on
PassengerAppRoot /home/impromptuindian/backend
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py

# Serve physical static files if they exist
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Everything else goes to Flask
RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,PT,L]
